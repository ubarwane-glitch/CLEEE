# Resend API Configuration
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx

# Email Configuration
# The "from" email address (must be verified in Resend)
FROM_EMAIL=noreply@yourdomain.com

# Business Configuration
BUSINESS_PHONE=06 77 23 58 39

# Optional: Send a copy of the quote to the client
# Set to 'true' to enable, 'false' to disable
SEND_COPY_TO_CLIENT=false

# Optional: Formspree Endpoint (if you want to use Formspree as fallback)
FORMSPREE_ENDPOINT=https://formspree.io/f/YOUR_FORM_ID
